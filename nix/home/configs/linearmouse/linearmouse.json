{
  "$schema" : "https://schema.linearmouse.app/0.11.0",
  "schemes" : [
    {
      "if" : {
        "app" : "com.mitchellh.ghostty"
      },
      "buttons" : {
        "mappings" : [
          {
            "button" : 2,
            "action" : "none"
          }
        ]
      }
    },
    {
      "if" : {
        "device" : {
          "category" : "mouse"
        }
      },
      "buttons" : {
        "gesture" : {
          "actions" : {
            "down" : "appExpose",
            "left" : "missionControl.spaceRight",
            "right" : "missionControl.spaceLeft",
            "up" : "missionControl"
          },
          "enabled" : true,
          "threshold" : 50,
          "trigger" : {
            "button" : 2
          }
        },
        "universalBackForward" : true
      },
      "scrolling" : {
        "reverse" : {
          "vertical" : true
        }
      }
    }
  ]
}
